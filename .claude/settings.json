{
  "mcpServers": {},
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "tools/drift-detector.sh 5 2>&1",
            "if": "Bash(git push*)",
            "timeout": 30,
            "statusMessage": "Checking for spec drift..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bin/check-milestones 2>&1",
            "show_output": true
          },
          {
            "type": "command",
            "command": "tools/drift-detector.sh 5 2>&1",
            "show_output": true
          }
        ]
      }
    ]
  }
}
