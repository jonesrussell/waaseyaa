#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="${ROOT_DIR:-$(cd "$(dirname "$0")/.." && pwd)}"
export ROOT_DIR

python3 - <<'PY'
import json
import os
import pathlib
import re
import sys

root = pathlib.Path(os.environ["ROOT_DIR"])

policy_id = {
    "sort_packages": "CP001",
    "dev_scope": "CP002",
    "no_wildcard_internal": "CP003",
    "core_runtime_surface": "CP004",
    "tight_internal_floor": "CP005",
    "self_version_scope": "CP006",
    "version_sync": "CP-NEW",
}

# ---------------------------------------------------------------------------
# CP-NEW: Cross-file internal constraint consistency.
# Every waaseyaa/* constraint in packages/*/composer.json must equal
# ^<current-git-tag> (the most recent vX.Y.Z tag on the repo).
#
# This depends on bin/lib/internal-version-sync.php (produced by WP01).
# If the lib file is absent, CP-NEW is skipped with a clear error so merge
# problems are loud, not silent.
# ---------------------------------------------------------------------------

import subprocess
import sys as _sys

_CP_NEW_LIB = os.path.join(os.path.dirname(os.path.abspath(__file__)), "lib", "internal-version-sync.php")
_CP_NEW_EXPECTED_VERSION = None   # str | None — None means skip
_CP_NEW_WARNING = None            # str | None — set when skipping with a reason

def _resolve_cp_new_expected() -> None:
    global _CP_NEW_EXPECTED_VERSION, _CP_NEW_WARNING

    # Strategy A: delegate to the shared PHP lib when it exists.
    if os.path.isfile(_CP_NEW_LIB):
        php_code = (
            "<?php "
            f"require '{_CP_NEW_LIB}'; "
            "try { echo resolveCurrentVersion(); } "
            "catch (\\RuntimeException $e) { fwrite(STDERR, $e->getMessage()); exit(2); }"
        )
        try:
            result = subprocess.run(
                ["php", "-r", php_code],
                capture_output=True, text=True, timeout=10
            )
            if result.returncode == 2:
                # resolveCurrentVersion() threw — no tags found
                _CP_NEW_WARNING = (
                    "CP-NEW skipped: git tag resolution failed "
                    f"({result.stderr.strip() or 'no tags found'}). "
                    "Run in a repo with at least one vX.Y.Z tag to enable this check."
                )
                return
            if result.returncode != 0:
                _CP_NEW_WARNING = (
                    f"CP-NEW skipped: bin/lib/internal-version-sync.php exited {result.returncode}: "
                    f"{result.stderr.strip()}"
                )
                return
            version = result.stdout.strip()
            if not version:
                _CP_NEW_WARNING = "CP-NEW skipped: resolveCurrentVersion() returned empty string."
                return
            _CP_NEW_EXPECTED_VERSION = version
        except (subprocess.TimeoutExpired, FileNotFoundError) as exc:
            _CP_NEW_WARNING = f"CP-NEW skipped: could not invoke php ({exc})."
        return

    # Strategy B (fallback): resolve git tag directly in Python.
    # This path is active before WP01 merges, or if the lib is unavailable.
    try:
        result = subprocess.run(
            ["git", "describe", "--tags", "--abbrev=0", "--match=v*.*.*"],
            capture_output=True, text=True, timeout=10,
            cwd=str(root)
        )
        if result.returncode != 0:
            _CP_NEW_WARNING = (
                "CP-NEW skipped: no git tags found matching v*.*.* — "
                "this is expected in shallow CI clones without fetch-tags: true "
                "and in local clones before the first release tag. "
                "Add 'fetch-tags: true' to the composer-policy CI job checkout step."
            )
            return
        raw = result.stdout.strip()
        version = raw.lstrip("v")
        if not version:
            _CP_NEW_WARNING = "CP-NEW skipped: git tag produced empty version string."
            return
        _CP_NEW_EXPECTED_VERSION = version
    except (subprocess.TimeoutExpired, FileNotFoundError) as exc:
        _CP_NEW_WARNING = f"CP-NEW skipped: could not run git ({exc})."

_resolve_cp_new_expected()


def fail_cp_new(rel_path: str, pkg: str, actual: str, expected: str) -> None:
    print(f"FAIL [CP-NEW] {rel_path}")
    print(f"  package:  {pkg}")
    print(f"  actual:   {actual}")
    print(f"  expected: {expected}")
    print(f"  fix:      run bin/sync-internal-versions after tagging, or run WP04 backfill")

# Cross-package constraints in publishable manifests must include an explicit
# pre-release floor (alpha/beta/rc/dev), otherwise Composer can resolve a
# stale sibling that lacks methods the current code calls. Discovered after
# alpha.150 entity-storage shipped a `quoteIdentifier()` call against a
# `^0.1` database-legacy constraint that resolved to alpha.145 in consumers.
# Bare `^0.X` floors are forbidden; `^0.1.0-alpha.N` is the required shape.
TIGHT_FLOOR_PATTERN = re.compile(r"-(alpha|beta|rc|dev)\.")

def fail(rule_key: str, rel_path: str, current: str, expected: str) -> None:
    rid = policy_id[rule_key]
    print(f"FAIL [{rid}] {rel_path}")
    print(f"  current: {current}")
    print(f"  expected: {expected}")

def _excluded(rel: str) -> bool:
    parts = set(rel.split("/"))
    return "vendor" in parts or "node_modules" in parts or rel.startswith(".worktrees/")


manifest_paths = sorted(
    [
        p for p in root.rglob("composer.json")
        if not _excluded(p.relative_to(root).as_posix())
    ]
)

in_scope = []
for path in manifest_paths:
    rel = path.relative_to(root).as_posix()
    if (
        rel == "composer.json"
        or rel.startswith("packages/")
        or rel.startswith("examples/")
        or rel.startswith("docs/examples/")
        or rel == "skeleton/composer.json"
    ):
        in_scope.append(path)

errors = 0

for path in in_scope:
    rel = path.relative_to(root).as_posix()
    data = json.loads(path.read_text())

    config = data.get("config", {})
    sort_packages = config.get("sort-packages")
    if sort_packages is not True:
        errors += 1
        fail(
            "sort_packages",
            rel,
            f"config.sort-packages={sort_packages!r}",
            "config.sort-packages=true",
        )

    package_sections = []
    for sec in ("require", "require-dev"):
        section = data.get(sec, {})
        if isinstance(section, dict):
            package_sections.append(section)

    for section in package_sections:
        for pkg, version in section.items():
            if not isinstance(version, str):
                continue

            if pkg.startswith("waaseyaa/"):
                # @dev policy: forbidden in published artifacts.
                # Root composer.json ships to Packagist as
                # `waaseyaa/framework` and consumers cannot resolve `@dev`.
                # Packages/* are split-published per package. Use
                # `self.version` in root for sibling metapackage
                # constraints; explicit semver ranges in packages/*.
                # examples/ and docs/examples/ are consumer demos that
                # track local path repos at dev-main — `@dev` is allowed.
                if version == "@dev" and (
                    rel == "composer.json" or rel.startswith("packages/")
                ):
                    errors += 1
                    fail(
                        "dev_scope",
                        rel,
                        f'{pkg}={version}',
                        '@dev forbidden — root must use self.version, '
                        'packages/* must use an explicit semver range',
                    )

                # self.version policy: only valid in root composer.json,
                # where it acts as a sibling-metapackage constraint that
                # resolves to the published tag. Outside root it has no
                # parent version to bind against in publishable artifacts.
                if version == "self.version" and rel != "composer.json":
                    errors += 1
                    fail(
                        "self_version_scope",
                        rel,
                        f'{pkg}={version}',
                        'self.version is only valid in the root '
                        'composer.json (waaseyaa/framework metapackage); '
                        'use an explicit semver range here',
                    )

                # Wildcard internal constraints forbidden everywhere.
                if "*" in version:
                    errors += 1
                    fail(
                        "no_wildcard_internal",
                        rel,
                        f'{pkg}={version}',
                        "use an explicit pre-release-anchored range "
                        "(for example ^0.1.0-alpha.150)",
                    )

                # Tight-floor policy: publishable manifests must anchor
                # cross-package constraints to a pre-release tag so Composer
                # cannot silently resolve a stale sibling. Root composer.json
                # uses self.version (exact match — strictly tighter than any
                # range). require-dev in skeleton/packages is also enforced —
                # test deps shipped to consumers.
                if (
                    rel != "composer.json"
                    and version != "@dev"
                    and version != "self.version"
                    and "*" not in version
                    and not TIGHT_FLOOR_PATTERN.search(version)
                ):
                    errors += 1
                    fail(
                        "tight_internal_floor",
                        rel,
                        f'{pkg}={version}',
                        "anchor to a pre-release floor "
                        "(for example ^0.1.0-alpha.150) so Composer cannot "
                        "resolve a stale sibling missing required methods",
                    )

    if rel == "packages/core/composer.json":
        require_section = data.get("require", {})
        if isinstance(require_section, dict):
            for forbidden_pkg in ("waaseyaa/debug", "waaseyaa/telescope", "waaseyaa/testing"):
                if forbidden_pkg in require_section:
                    errors += 1
                    fail(
                        "core_runtime_surface",
                        rel,
                        f'{forbidden_pkg} in require',
                        f"move {forbidden_pkg} to suggest (core runtime must remain install-safe)",
                    )

# ---------------------------------------------------------------------------
# CP-NEW run: compare every packages/*/composer.json waaseyaa/* constraint
# against the expected ^<current-version> literal.
# ---------------------------------------------------------------------------

if _CP_NEW_WARNING:
    print(f"WARNING [CP-NEW] {_CP_NEW_WARNING}", file=sys.stderr)
elif _CP_NEW_EXPECTED_VERSION is not None:
    expected_constraint = f"^{_CP_NEW_EXPECTED_VERSION}"
    for path in in_scope:
        rel = path.relative_to(root).as_posix()
        # CP-NEW only applies to per-package manifests, not root.
        if not rel.startswith("packages/"):
            continue
        data = json.loads(path.read_text())
        for sec in ("require", "require-dev"):
            section = data.get(sec, {})
            if not isinstance(section, dict):
                continue
            for pkg, version in section.items():
                if not isinstance(version, str):
                    continue
                if pkg.startswith("waaseyaa/") and version != expected_constraint:
                    # Only flag constraints that pass the tight-floor shape
                    # (i.e. have a pre-release anchor). Non-anchored literals
                    # are already caught by CP005; flagging them twice adds noise.
                    if TIGHT_FLOOR_PATTERN.search(version):
                        errors += 1
                        fail_cp_new(rel, pkg, version, expected_constraint)

if errors == 0:
    print("OK: Composer policy checks passed")
    sys.exit(0)

print(f"Composer policy check failed with {errors} violation(s)")
sys.exit(1)
PY
