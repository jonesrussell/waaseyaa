#!/usr/bin/env bash
#
# check-symfony-imports — enforce the Path R-narrow Symfony-import boundary
# ratified in mission #1107 (C-005 (b)). Fails when a `use Symfony\…` line
# appears outside the framework allowlist.
#
# Usage:
#   bin/check-symfony-imports                # check all packages
#   bin/check-symfony-imports --list-stale   # also report legacy_files
#                                            #   entries that no longer have
#                                            #   any Symfony imports (stale)
#
# Exit codes:
#   0 — clean
#   1 — one or more disallowed `use Symfony\…` imports found
#   2 — stale legacy_files entries found (only with --list-stale)

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
export ROOT_DIR
export LIST_STALE="${1:-}"

python3 - <<'PY'
import json
import os
import pathlib
import re
import sys

root = pathlib.Path(os.environ["ROOT_DIR"])
list_stale = os.environ.get("LIST_STALE") == "--list-stale"

config_path = root / ".symfony-import-allowlist.json"
if not config_path.exists():
    print(f"ERROR: missing {config_path.relative_to(root)}", file=sys.stderr)
    sys.exit(1)

with config_path.open() as f:
    config = json.load(f)

allowed_dirs = [
    (root / d).resolve() for d in config.get("allowed_directories", [])
]
legacy_files = {
    (root / f).resolve() for f in config.get("legacy_files", [])
}

# Matches `use Symfony\...`, `use function Symfony\...`, `use const Symfony\...`.
# Ignores leading whitespace (e.g. nested namespace blocks).
SYMFONY_USE_RE = re.compile(r"^\s*use\s+(?:function\s+|const\s+)?Symfony\\")

def is_in_allowed_dir(file_path: pathlib.Path) -> bool:
    for allowed in allowed_dirs:
        try:
            file_path.relative_to(allowed)
            return True
        except ValueError:
            continue
    return False

def has_symfony_import(file_path: pathlib.Path) -> bool:
    try:
        with file_path.open(encoding="utf-8", errors="replace") as f:
            for line in f:
                if SYMFONY_USE_RE.match(line):
                    return True
    except OSError:
        pass
    return False

# Scan `packages/*/src/**/*.php` — application src trees only. Tests are
# implicitly allowed (the boundary is for shipping code, not test scaffolding).
violations: list[tuple[pathlib.Path, int, str]] = []
seen_legacy_files: set[pathlib.Path] = set()

for php_file in sorted(root.glob("packages/*/src/**/*.php")):
    resolved = php_file.resolve()

    if is_in_allowed_dir(resolved):
        continue

    # Find the first offending line for diagnostic output.
    first_match: tuple[int, str] | None = None
    try:
        with php_file.open(encoding="utf-8", errors="replace") as f:
            for lineno, line in enumerate(f, start=1):
                if SYMFONY_USE_RE.match(line):
                    first_match = (lineno, line.rstrip())
                    break
    except OSError:
        continue

    if first_match is None:
        continue

    if resolved in legacy_files:
        seen_legacy_files.add(resolved)
        continue

    relative = php_file.relative_to(root)
    violations.append((relative, first_match[0], first_match[1]))

if violations:
    print("Disallowed Symfony imports outside the allowlist:")
    print()
    for rel, lineno, text in violations:
        print(f"  {rel}:{lineno}: {text}")
    print()
    print(f"{len(violations)} violation(s) found.")
    print()
    print("Resolve by either:")
    print("  - Replacing the import with the equivalent Waaseyaa surface")
    print("    (e.g. `Waaseyaa\\Foundation\\Http\\Request` for the HTTP type).")
    print("  - Adding the file to `legacy_files` in")
    print("    `.symfony-import-allowlist.json` if the import is genuinely")
    print("    unavoidable. Document why in the PR description.")
    sys.exit(1)

if list_stale:
    stale = sorted(legacy_files - seen_legacy_files)
    # Filter to legacy entries that still exist on disk — files that were
    # deleted are reported separately so they don't get conflated with
    # successfully-refactored entries.
    deleted = [p for p in stale if not p.exists()]
    refactored = [p for p in stale if p.exists() and not has_symfony_import(p)]

    if deleted:
        print("Stale legacy_files entries (file no longer exists):")
        for p in deleted:
            print(f"  {p.relative_to(root)}")
        print()

    if refactored:
        print("Stale legacy_files entries (file no longer has Symfony imports):")
        for p in refactored:
            print(f"  {p.relative_to(root)}")
        print()
        print("Remove these entries from `.symfony-import-allowlist.json`.")

    if deleted or refactored:
        sys.exit(2)

print("OK — Symfony-import boundary clean.")
PY
