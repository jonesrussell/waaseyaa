#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
export ROOT_DIR

python3 - <<'PY'
import json
import os
import pathlib
import re

root = pathlib.Path(os.environ["ROOT_DIR"])

layer_by_short = {
    "foundation": 0, "cache": 0, "plugin": 0, "typed-data": 0, "database-legacy": 0,
    "i18n": 0, "queue": 0, "scheduler": 0, "state": 0, "validation": 0, "mail": 0,
    "http-client": 0, "ingestion": 0, "error-handler": 0, "geo": 0, "mercure": 0,
    "analytics": 0, "oauth-provider": 0,
    "entity": 1, "entity-storage": 1, "access": 1, "user": 1, "config": 1,
    "field": 1, "auth": 1, "testing": 1, "oidc": 1,
    "node": 2, "taxonomy": 2, "media": 2, "path": 2, "menu": 2, "note": 2,
    "relationship": 2, "groups": 2, "engagement": 2, "messaging": 2,
    "workflows": 3, "search": 3, "seo": 3, "notification": 3, "billing": 3,
    "github": 3, "northcloud": 3,
    "api": 4, "routing": 4, "bimaaji": 4,
    "ai-schema": 5, "ai-agent": 5, "ai-pipeline": 5, "ai-vector": 5, "ai-observability": 5,
    "cli": 6, "admin": 6, "admin-surface": 6, "graphql": 6, "mcp": 6, "ssr": 6,
    "genealogy": 6, "telescope": 6, "deployer": 6, "inertia": 6, "debug": 6,
}
metapackages = {"cms", "core", "full"}
name_rx = re.compile(r"^waaseyaa/([a-z0-9-]+)$", re.I)

def short(name: str):
    m = name_rx.match(name.strip())
    return m.group(1).lower() if m else None

warnings: list[str] = []
for pkg_dir in sorted((root / "packages").iterdir()):
    if not pkg_dir.is_dir():
        continue
    manifest = pkg_dir / "composer.json"
    if not manifest.is_file():
        continue
    data = json.loads(manifest.read_text())
    if data.get("type") == "metapackage" or pkg_dir.name in metapackages:
        continue
    self_short = short(data.get("name", ""))
    if self_short is None or self_short not in layer_by_short:
        continue
    self_layer = layer_by_short[self_short]

    require_dev = data.get("require-dev", {})
    if not isinstance(require_dev, dict):
        continue
    for dep, _version in require_dev.items():
        dep_short = short(dep)
        if dep_short is None or dep_short not in layer_by_short:
            continue
        dep_layer = layer_by_short[dep_short]
        if dep_layer > self_layer:
            warnings.append(
                f"WARN [PLD001] {manifest.relative_to(root)} require-dev: "
                f"{self_short}(L{self_layer}) -> {dep_short}(L{dep_layer})"
            )

if warnings:
    print("require-dev layer audit warnings (non-fatal):")
    for w in warnings:
        print("  " + w)
    print(f"Total warnings: {len(warnings)}")
else:
    print("OK — require-dev layer audit found no upward waaseyaa/* edges.")
PY
