#!/usr/bin/env bash
#
# check-admin-coercion-patterns — CI gate for admin SPA raw coercion patterns
#
# Prevents regression of the useAdminConfig() migration (mission M-F,
# admin-spa-realtime-config-contract-01KS3ST4). After WP02/WP03 migrated
# all 17 call sites to typed coercion helpers, direct string-compare patterns
# like `=== '1'` or `=== '0'` must not reappear in admin SPA source files.
#
# EXEMPTION MECHANISM
# -------------------
# If a file has a legitimate reason to use a raw coercion pattern (e.g.
# URL query parsing in auth flows, localStorage reads, the coercion helpers
# themselves, or test files), add an inline comment on the offending line:
#
#   const val = someQuery === '1' // allow-coercion: URL query param, not a runtime-config value
#
# Lines containing `// allow-coercion:` are excluded from the check.
# Test files (*.test.ts, *.spec.ts, files under e2e/) are always excluded.
# The coercion helpers file itself (configCoercion.ts) is always excluded.
#
# EXIT CODES
# ----------
# 0 — no violations found
# 1 — one or more violations found (prints each offending file:line)

set -euo pipefail

WORKTREE_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ADMIN_DIR="${WORKTREE_ROOT}/packages/admin/app"

# --self-test mode: create a synthetic violator, assert non-zero exit, clean up.
if [[ "${1:-}" == "--self-test" ]]; then
    TEMP_VIOLATOR="${ADMIN_DIR}/_selftest_violator_$$.ts"
    trap 'rm -f "$TEMP_VIOLATOR"' EXIT
    printf 'const x = something === "1"\n' > "$TEMP_VIOLATOR"
    exit_code=0
    bash "${BASH_SOURCE[0]}" > /dev/null 2>&1 || exit_code=$?
    if [[ $exit_code -ne 0 ]]; then
        echo "check-admin-coercion-patterns --self-test: PASSED (gate correctly exits $exit_code on synthetic violation)"
        exit 0
    else
        echo "check-admin-coercion-patterns --self-test: FAILED (gate returned 0 on synthetic violation — gate is broken)" >&2
        exit 1
    fi
fi

# Patterns that indicate raw coercion bypassing useAdminConfig()
# We look for comparisons directly against '1' or '0' that are NOT in
# coercion helpers, test files, or explicitly exempted lines.
# Uses -P (Perl-compatible regex) only — combining -E and -P is not supported.
COMBINED_PATTERN="(=== '1'|=== '0'|=== \"1\"|=== \"0\"|String\([^)]*\) === '1'|String\([^)]*\) === '0')"

found_violations=0
violation_lines=()

# Find all .ts and .vue files in packages/admin/app
while IFS= read -r -d '' file; do
    # Skip the coercion helpers themselves
    if [[ "$file" == *"configCoercion.ts" ]]; then
        continue
    fi
    # Skip test files
    if [[ "$file" == *.test.ts ]] || [[ "$file" == *.spec.ts ]]; then
        continue
    fi

    # Grep for patterns using -P (Perl regex); suppress only "no match" (exit 1),
    # let real errors (exit 2+) surface so CI does not silently skip files.
    grep_output=""
    grep_exit=0
    grep_output=$(grep -nP "$COMBINED_PATTERN" "$file") || grep_exit=$?
    if [[ $grep_exit -ge 2 ]]; then
        echo "check-admin-coercion-patterns: grep error scanning $file (exit $grep_exit)" >&2
        exit 2
    fi
    if [[ -z "$grep_output" ]]; then
        continue
    fi

    while IFS= read -r match_line; do
        # Skip exempted lines
        if echo "$match_line" | grep -qF '// allow-coercion:'; then
            continue
        fi
        violation_lines+=("${file}:${match_line}")
        found_violations=1
    done <<< "$grep_output"
done < <(find "${ADMIN_DIR}" -type f \( -name "*.ts" -o -name "*.vue" \) -print0)

# Also check e2e directory — but skip spec files (they're excluded above via *.spec.ts)
# Actually skip all e2e files from this check (they may test env values directly)
# The find above is scoped to app/ only, so e2e is already excluded.

if [[ $found_violations -eq 1 ]]; then
    echo "check-admin-coercion-patterns: FAILED" >&2
    echo "" >&2
    echo "Found raw coercion pattern(s) in admin SPA source." >&2
    echo "Use useAdminConfig() with asBoolean()/asString()/asUrl() instead." >&2
    echo "" >&2
    echo "Offending locations:" >&2
    for line in "${violation_lines[@]}"; do
        echo "  $line" >&2
    done
    echo "" >&2
    echo "To exempt a line with a valid reason, add: // allow-coercion: <reason>" >&2
    exit 1
fi

echo "check-admin-coercion-patterns: OK"
exit 0
