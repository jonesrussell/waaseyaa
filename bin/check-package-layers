#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
export ROOT_DIR

python3 - <<'PY'
import json
import os
import pathlib
import re
import sys

root = pathlib.Path(os.environ["ROOT_DIR"])

# Canonical layer index (0 = foundation). Must match CLAUDE.md "Layer Architecture".
# waaseyaa/<short> maps to directory packages/<short>/
LAYER_BY_SHORT = {
    # 0 — Foundation
    "foundation": 0,
    "cache": 0,
    "plugin": 0,
    "typed-data": 0,
    "database-legacy": 0,
    "i18n": 0,
    "queue": 0,
