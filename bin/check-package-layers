    "mercure": 0,
    "analytics": 0,
    "oauth-provider": 0,
    # 1 — Core data (testing ships entity fixtures; composer requires entity — see CLAUDE.md)
    "entity": 1,
    "entity-storage": 1,
    "access": 1,
    "user": 1,
    "config": 1,
    "field": 1,
    "auth": 1,
    "testing": 1,
    "oidc": 1,
    # 2 — Content types
    "attachment": 2,
    "node": 2,
    "taxonomy": 2,
    "media": 2,
    "path": 2,
    "menu": 2,
    "note": 2,
    "relationship": 2,
    "groups": 2,
    "engagement": 2,
    "messaging": 2,
    # 3 — Services
    "workflows": 3,
    "search": 3,
    "seo": 3,
    "notification": 3,
    "billing": 3,
    "github": 3,
    "northcloud": 3,
    "structured-import": 3,
    "migration": 3,
    # 4 — API
    "api": 4,
    "routing": 4,
    "bimaaji": 4,
    # 5 — AI
    "ai-schema": 5,
    "ai-agent": 5,
    "ai-pipeline": 5,
    "ai-vector": 5,
    "ai-observability": 5,
    # 6 — Interfaces
    # Note: packages/admin/ is a Nuxt SPA (no composer.json, no PHP source) —
    # not part of the PHP layer graph. Its PHP host extension is waaseyaa/admin-surface.
    "cli": 6,
    "admin-surface": 6,
    "graphql": 6,
    "mcp": 6,
    "ssr": 6,
    "genealogy": 6,
    "telescope": 6,
    "deployer": 6,
    "inertia": 6,
    "debug": 6,
}

METAPACKAGES = frozenset({"cms", "core", "full"})

WAASEYAA_NAME = re.compile(r"^waaseyaa/([a-z0-9-]+)$", re.I)

# ---------------------------------------------------------------------------
# Kernel exemption surface (mission #824 WP02 surface C)
#
# Two complementary mechanisms relax the file-level layer rule for
# bootstrapper code that intentionally sees across layers.
#
# 1. KERNEL_EXEMPT_DIR_SUFFIXES — implicit dir-prefix exemption.
#    Any PHP file whose path (relative to packages/) ends up under one of
#    these suffixes is treated as kernel/bootstrapper code. This is the
#    canonical exemption documented in CLAUDE.md "Layer Architecture".
#
# 2. KERNEL_EXEMPT_FILES — explicit named-file allowlist.
#    Each entry maps a path (relative to packages/) to a one-line rationale.
#    Use this for kernel-adjacent files that must live outside <pkg>/src/Kernel/
#    (e.g. listeners, route registrars, diagnostics wired only from a kernel).
#    Adding an entry is the deliberate way to land such files; future drift
#    that does not earn an entry will fail the gate.
# ---------------------------------------------------------------------------

KERNEL_EXEMPT_DIR_SUFFIXES = ("/src/Kernel/",)

KERNEL_EXEMPT_FILES = {
    # foundation — kernel-adjacent diagnostics wired only from ConsoleKernel.
    # Codified per mission #824 WP02 K6(c); HealthChecker is verified by
    # mission #1257 WP02 / #1300.
    "foundation/src/Diagnostic/HealthChecker.php":
        "kernel-adjacent diagnostic wired only from ConsoleKernel; #1300 / mission 1257 K6(c)",
    "foundation/src/Diagnostic/BootDiagnosticReport.php":
        "kernel-adjacent diagnostic; companion to HealthChecker",

    # foundation — kernel-adjacent HTTP route registrars wired only from HttpKernel.
    # Long-term home is L4 (waaseyaa/routing); kept here until relocation lands.
    "foundation/src/Http/Router/BroadcastRouter.php":
        "kernel-adjacent route registrar wired from HttpKernel",
    "foundation/src/Http/Router/CodifiedContextApiRouter.php":
        "kernel-adjacent route registrar wired from HttpKernel",
    "foundation/src/Http/Router/EntityTypeLifecycleRouter.php":
        "kernel-adjacent route registrar wired from HttpKernel",
    "foundation/src/Http/Router/JsonApiRouter.php":
        "kernel-adjacent route registrar wired from HttpKernel",
    "foundation/src/Http/Router/McpRouter.php":
        "kernel-adjacent route registrar wired from HttpKernel",
    "foundation/src/Http/Router/SchemaRouter.php":
        "kernel-adjacent route registrar wired from HttpKernel",
    "foundation/src/Http/Router/SearchRouter.php":
        "kernel-adjacent route registrar wired from HttpKernel",
    "foundation/src/Http/Router/WorkflowDefinitionsApiRouter.php":
        "kernel-adjacent route registrar wired from HttpKernel",
    "foundation/src/Http/Router/WaaseyaaContext.php":
        "kernel-adjacent route registrar wired from HttpKernel",

    # foundation — kernel-boot listener wiring extracted from HttpKernel for testability.
    # Already covered by the implicit /src/Kernel/ dir exemption; the explicit entry
    # records architectural intent per mission #824 WP02 surface B (issue #827).
    "foundation/src/Kernel/EventListenerRegistrar.php":
        "kernel-boot listener wiring; pure dispatcher::addListener calls; single caller (HttpKernel)",

    # foundation — kernel-adjacent service-provider capability interfaces consumed
    # only by ConsoleKernel/HttpKernel. They type-hint EntityTypeManager (L1) for
    # hook signatures so the kernel can wire commands, middleware, and graphql
    # mutation overrides through a typed contract rather than reflection. They are
    # not reusable library code — every consumer is a kernel call site. Mission
    # #824 WP03 surfaces D-F introduced these capability hooks; surfacing
    # `composer verify` (WP09 surface A) requires the layer gate to pass cleanly.
    "foundation/src/ServiceProvider/Capability/HasCommandsInterface.php":
        "kernel-adjacent capability interface consumed only by ConsoleKernel; #824 WP03 surface E",
    "foundation/src/ServiceProvider/Capability/HasMiddlewareInterface.php":
        "kernel-adjacent capability interface consumed only by HttpKernel middleware pipeline; #824 WP03 surface D",
    "foundation/src/ServiceProvider/Capability/HasGraphqlMutationOverridesInterface.php":
        "kernel-adjacent capability interface consumed only by GraphQL bootstrap from kernel context; #824 WP03 surface F",

    # cache — event listeners wired by ServiceProvider; subscribe to higher-layer events.
    "cache/src/Listener/ConfigCacheInvalidator.php":
        "event listener; subscribes to L1 config events for cache invalidation",
    "cache/src/Listener/EntityCacheInvalidator.php":
        "event listener; subscribes to L1 entity events for cache invalidation",
    "cache/src/Listener/EntityCacheSubscriber.php":
        "event listener; subscribes to L1 entity events for cache invalidation",

    # cache — kernel-resolved cache key derivation; consumes AccountInterface.
    "cache/src/CacheConfigResolver.php":
        "kernel-resolved cache config; consumes AccountInterface for cache-key derivation",
}


def short_from_package_name(name: str) -> str | None:
    m = WAASEYAA_NAME.match(name.strip())
    return m.group(1).lower() if m else None


def is_kernel_exempt(rel_to_packages: str) -> bool:
    """Return True if a file (path relative to packages/) is kernel-exempt."""
    norm = "/" + rel_to_packages
    if any(suffix in norm for suffix in KERNEL_EXEMPT_DIR_SUFFIXES):
        return True
    if rel_to_packages in KERNEL_EXEMPT_FILES:
        return True
    return False


# ---------------------------------------------------------------------------
# Namespace → package short mapping for PHP `use` import scanning.
# Keep aligned with PSR-4 prefixes declared in each package's composer.json.
# ---------------------------------------------------------------------------

NS_PREFIX_TO_SHORT = {
    "Foundation": "foundation",
    "Cache": "cache",
    "Plugin": "plugin",
    "TypedData": "typed-data",
    "Database": "database-legacy",
    "I18n": "i18n",
    "Queue": "queue",
    "Scheduler": "scheduler",
    "State": "state",
    "Validation": "validation",
    "Mail": "mail",
    "HttpClient": "http-client",
    "Ingestion": "ingestion",
    "ErrorHandler": "error-handler",
    "Geo": "geo",
    "Mercure": "mercure",
    "Analytics": "analytics",
    "OAuthProvider": "oauth-provider",
    "Entity": "entity",
    "EntityStorage": "entity-storage",
    "Access": "access",
    "User": "user",
    "Config": "config",
    "Field": "field",
    "Auth": "auth",
    "Testing": "testing",
    "Oidc": "oidc",
    "Node": "node",
    "Taxonomy": "taxonomy",
    "Media": "media",
    "Path": "path",
    "Menu": "menu",
    "Note": "note",
    "Relationship": "relationship",
    "Groups": "groups",
    "Engagement": "engagement",
    "Messaging": "messaging",
    "Workflows": "workflows",
    "Search": "search",
    "Seo": "seo",
    "Notification": "notification",
    "Billing": "billing",
    "Github": "github",
    "Northcloud": "northcloud",
    "Api": "api",
    "Routing": "routing",
    "Bimaaji": "bimaaji",
    # AI sub-namespaces are disambiguated via the second segment below.
    "Cli": "cli",
    "Admin": "admin",
    "AdminSurface": "admin-surface",
    "Graphql": "graphql",
    "Mcp": "mcp",
    "Ssr": "ssr",
    "Genealogy": "genealogy",
    "Telescope": "telescope",
    "Deployer": "deployer",
    "Inertia": "inertia",
    "Debug": "debug",
}

AI_SUB_TO_SHORT = {
    "Schema": "ai-schema",
    "Agent": "ai-agent",
    "Pipeline": "ai-pipeline",
    "Vector": "ai-vector",
    "Observability": "ai-observability",
}

USE_RE = re.compile(
    r"^\s*use(?:\s+function|\s+const)?\s+Waaseyaa\\([A-Z][A-Za-z0-9]*)(?:\\([A-Z][A-Za-z0-9]*))?",
    re.M,
)


def short_for_namespace(first: str, second: str | None) -> str | None:
    if first == "AI":
        return AI_SUB_TO_SHORT.get(second or "")
    return NS_PREFIX_TO_SHORT.get(first)


def scan_php_imports(pkg_dir: pathlib.Path, self_layer: int) -> list[tuple[str, str, int]]:
    """Return list of (relative_path, dep_short, dep_layer) for cross-layer file-level imports."""
    findings: list[tuple[str, str, int]] = []
    src = pkg_dir / "src"
    if not src.is_dir():
        return findings
    for php in src.rglob("*.php"):
        rel = str(php.relative_to(root / "packages"))
        if is_kernel_exempt(rel):
            continue
        try:
            text = php.read_text(errors="replace")
        except OSError:
            continue
        seen: set[str] = set()
        for m in USE_RE.finditer(text):
            short = short_for_namespace(m.group(1), m.group(2))
            if short is None or short not in LAYER_BY_SHORT:
                continue
            if short in seen:
                continue
            seen.add(short)
            dep_layer = LAYER_BY_SHORT[short]
            if dep_layer > self_layer:
                findings.append((rel, short, dep_layer))
    return findings


# ---------------------------------------------------------------------------
# Run checks.
# ---------------------------------------------------------------------------

errors = 0
packages_dir = root / "packages"

if not packages_dir.is_dir():
    print("FAIL [PL000] packages/ not found", file=sys.stderr)
    sys.exit(1)

for pkg_dir in sorted(packages_dir.iterdir()):
    if not pkg_dir.is_dir():
        continue
    manifest = pkg_dir / "composer.json"
    if not manifest.is_file():
        continue
    data = json.loads(manifest.read_text())
    pkg_type = data.get("type", "library")
    if pkg_type == "metapackage" or pkg_dir.name in METAPACKAGES:
        continue

    name = data.get("name", "")
    short = short_from_package_name(name) if name else None
    if short is None:
        continue
    if short != pkg_dir.name:
        errors += 1
        print(f"FAIL [PL001] {manifest.relative_to(root)}: name {name!r} does not match directory {pkg_dir.name!r}")
        continue

    if short not in LAYER_BY_SHORT:
        errors += 1
        print(
            f"FAIL [PL002] {manifest.relative_to(root)}: package {short!r} missing from bin/check-package-layers LAYER_BY_SHORT — add layer and update CLAUDE.md"
        )
        continue

    layer_self = LAYER_BY_SHORT[short]

    # ----- composer.json runtime require edges -----
    # Runtime edges only: require-dev frequently pulls higher-layer packages for
    # PHPUnit fixtures (e.g. media -> api). Composer policy still applies to dev.
    for sec in ("require",):
        section = data.get(sec, {})
        if not isinstance(section, dict):
            continue
        for dep_name, _ver in section.items():
            dep_short = short_from_package_name(dep_name)
            if dep_short is None:
                continue
            if dep_short not in LAYER_BY_SHORT:
                errors += 1
                print(
                    f"FAIL [PL003] {manifest.relative_to(root)} {sec}: dependency {dep_name!r} (short={dep_short!r}) not in LAYER_BY_SHORT"
                )
                continue
            layer_dep = LAYER_BY_SHORT[dep_short]
            if layer_dep > layer_self:
                errors += 1
                print(
                    f"FAIL [PL004] {manifest.relative_to(root)} {sec}: layer violation — "
                    f"{short} (layer {layer_self}) must not depend on {dep_short} (layer {layer_dep}). "
                    f"See CLAUDE.md Layer Architecture and GitHub #315/#316."
                )

    # ----- PHP file-level `use` imports -----
    for rel, dep_short, dep_layer in scan_php_imports(pkg_dir, layer_self):
        errors += 1
        print(
            f"FAIL [PL005] packages/{rel}: file-level layer violation — "
            f"{short} (layer {layer_self}) imports waaseyaa/{dep_short} (layer {dep_layer}). "
            f"If this file is kernel-adjacent, move it under {short}/src/Kernel/ or add an "
            f"entry to KERNEL_EXEMPT_FILES in bin/check-package-layers with a one-line rationale."
        )

if errors:
    print(f"\nPackage layer check failed with {errors} error(s).", file=sys.stderr)
    sys.exit(1)

print("OK — package layer constraints (composer.json + PHP file-level) satisfied.")
PY
