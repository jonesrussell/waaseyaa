#!/usr/bin/env bash
# check-openapi — Validate packages/api/openapi.yaml against OpenAPI 3.1.0 spec.
#
# Used as a hard gate in `composer verify` (NFR-004 / WP02).
# Requires Node.js + npx for the @stoplight/spectral-cli linter.
# If npx is unavailable, emits a SKIP notice and exits 0 (CI-safe fallback).
#
# Usage: bin/check-openapi [path/to/openapi.yaml]
#        Defaults to packages/api/openapi.yaml when no argument is given.

set -euo pipefail

OPENAPI_FILE="${1:-packages/api/openapi.yaml}"

if [[ ! -f "$OPENAPI_FILE" ]]; then
    echo "check-openapi: ERROR: $OPENAPI_FILE not found" >&2
    exit 1
fi

if ! command -v npx &>/dev/null; then
    echo "check-openapi: SKIP: npx not available — install Node.js to enable OpenAPI linting" >&2
    exit 0
fi

# Run Spectral lint.  --ruleset .spectral.yaml if the file exists at root;
# fall back to the built-in spectral:oas ruleset.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
RULESET="${REPO_ROOT}/.spectral.yaml"

if [[ -f "$RULESET" ]]; then
    npx --yes @stoplight/spectral-cli@^6 lint "$OPENAPI_FILE" --ruleset "$RULESET"
else
    npx --yes @stoplight/spectral-cli@^6 lint "$OPENAPI_FILE"
fi
