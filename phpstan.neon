includes:
    - vendor/phpstan/phpstan-strict-rules/rules.neon
    - phpstan-baseline.neon
    - packages/entity/phpstan-rules.neon

parameters:
    level: 5
    phpVersion: 80500
    tmpDir: tmp/phpstan
    checkUninitializedProperties: true
    checkBenevolentUnionTypes: true
    reportPossiblyNonexistentGeneralArrayOffset: true
    reportPossiblyNonexistentConstantArrayOffset: true
    paths:
        - packages/access/src
        # admin: Nuxt SPA — excluded per Convention C3 (mission #1335 spec.md). PHP host is admin-surface (L6).
        - packages/admin-surface/src
        - packages/ai-agent/src
        - packages/ai-observability/src
        - packages/ai-pipeline/src
        - packages/ai-schema/src
        - packages/ai-tools/src
        - packages/ai-vector/src
        - packages/api/src
        - packages/auth/src
        - packages/billing/src
        - packages/bimaaji/src
        - packages/analytics/src
        - packages/cache/src
        - packages/cli/src
        - packages/config/src
        - packages/database-legacy/src
        - packages/debug/src
        # deployer: recipe-only package (no PSR-4 src/) — single Deployer recipe file at recipe/waaseyaa.php depends on deployphp/deployer's globally-bound functions (run/task/desc/get/after) that PHPStan cannot resolve without project-specific stubs. Excluded per Convention C3 (mission #1335 spec.md).
        - packages/entity-storage/src
        - packages/entity/src
        - packages/engagement/src
        - packages/error-handler/src
        - packages/field/src
        - packages/foundation/src
        - packages/geo/src
        - packages/groups/src
        - packages/github/src
        - packages/genealogy/src
        - packages/graphql/src

        - packages/i18n/src
        - packages/http-client/src
        - packages/inertia/src
        - packages/ingestion/src
        - packages/listing/src
        - packages/mail/src
        - packages/mcp/src
        - packages/media/src
        - packages/mercure/src
        - packages/menu/src
        - packages/messaging/src
        - packages/migration/src
        - packages/node/src
        - packages/northcloud/src
        - packages/note/src
        - packages/oauth-provider/src
        - packages/notification/src
        - packages/oidc/src
        - packages/path/src
        - packages/plugin/src
        - packages/queue/src
        - packages/relationship/src
        - packages/scheduler/src
        - packages/routing/src
        - packages/search/src
        - packages/seo/src
        - packages/ssr/src
        - packages/state/src
        - packages/taxonomy/src
        - packages/telescope/src
        - packages/testing/src
        - packages/typed-data/src
        - packages/user/src
        - packages/validation/src
        - packages/workflows/src
