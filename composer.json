    "scripts": {
        "check-composer-policy": "bash bin/check-composer-policy",
        "check-ingestion-defaults": "bash bin/check-ingestion-defaults",
        "check-no-secrets": "bash bin/check-no-secrets",
        "check-package-layers": "bash bin/check-package-layers",
        "check-symfony-imports": "bash bin/check-symfony-imports",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "@dev:php"
        ],
        "dev:admin": [
            "Composer\\Config::disableProcessTimeout",
            "NUXT_BACKEND_URL=http://127.0.0.1:${APP_PORT:-8080} bin/waaseyaa admin:dev"
        ],
        "dev:php": [
            "Composer\\Config::disableProcessTimeout",
            "PHP_CLI_SERVER_WORKERS=4 bin/waaseyaa serve"
        ],
        "phpstan": "phpstan analyse --memory-limit=512M",
        "test": "phpunit --no-coverage",
        "verify": [
            "@cs-check",
            "@phpstan",
            "@check-composer-policy",
            "@check-package-layers",
            "@check-no-secrets",
            "@check-ingestion-defaults",
            "@check-symfony-imports",
            "@test"
        ]
    },
    "scripts-descriptions": {
        "check-symfony-imports": "Enforce the Path R-narrow Symfony-import boundary (mission #1107 C-005 (b)). Fails when `use Symfony\\…` appears outside the framework allowlist. Allowlist lives in .symfony-import-allowlist.json — see docs/specs/api-layer.md §Symfony Import Boundary.",
        "dev": "Start the PHP dev server (delegates to dev:php). For the admin SPA, run `composer dev:admin` in a second terminal — see docs/specs/operations-playbooks.md.",
        "dev:admin": "Start the Nuxt admin SPA dev server. NUXT_BACKEND_URL points at the PHP server (default :8080); set APP_PORT to override.",
        "dev:php": "Start the PHP built-in dev server via bin/waaseyaa serve. Single typed long-running process with no shell forking.",
        "verify": "Run all repo-wide gates: cs-check, phpstan, composer-policy, package-layers, no-secrets, ingestion-defaults, symfony-imports, and the test suite. Canonical CI entry point — see docs/specs/operations-playbooks.md."
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {}
    },
    "extra": {
        "waaseyaa": {
            "admin_path": "packages/admin",
            "providers": []
        }
    }
}
