{
    "name": "waaseyaa/entity-storage",
    "description": "Pluggable entity persistence. v0.1.0: SQL storage behind clean interfaces.",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "repositories": [
        {
            "type": "path",
            "url": "../access"
        },
        {
            "type": "path",
            "url": "../entity"
        },
        {
            "type": "path",
            "url": "../field"
        },
        {
            "type": "path",
            "url": "../foundation"
        },
        {
            "type": "path",
            "url": "../cache"
        },
        {
            "type": "path",
            "url": "../database-legacy"
        },
        {
            "type": "path",
            "url": "../plugin"
        },
        {
            "type": "path",
            "url": "../typed-data"
        },
        {
            "type": "path",
            "url": "../config"
        },
        {
            "type": "path",
            "url": "../i18n"
        }
    ],
    "require": {
        "php": ">=8.5",
        "waaseyaa/access": "^0.1.0-alpha.181",
        "waaseyaa/cache": "^0.1.0-alpha.181",
        "waaseyaa/config": "^0.1.0-alpha.181",
        "waaseyaa/database-legacy": "^0.1.0-alpha.181",
        "waaseyaa/entity": "^0.1.0-alpha.181",
        "waaseyaa/field": "^0.1.0-alpha.181",
        "waaseyaa/foundation": "^0.1.0-alpha.181",
        "waaseyaa/i18n": "^0.1.0-alpha.181",
        "symfony/event-dispatcher": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Waaseyaa\\EntityStorage\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\EntityStorage\\Testing\\Contract\\": "testing/Contract/",
            "Waaseyaa\\EntityStorage\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev",
            "dev-develop/v1.1": "0.1.x-dev"
        }
    },
    "config": {
        "sort-packages": true
    }
}
