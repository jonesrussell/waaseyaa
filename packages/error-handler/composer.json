{
    "name": "waaseyaa/error-handler",
    "description": "Rich exception pages, solution hints, and editor links for Waaseyaa",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.5",
        "waaseyaa/foundation": "^0.1.0-alpha.179"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Waaseyaa\\ErrorHandler\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\ErrorHandler\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev",
            "dev-develop/v1.1": "0.1.x-dev"
        }
    },
    "config": {
        "sort-packages": true
    }
}
