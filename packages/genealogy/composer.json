{
    "name": "waaseyaa/genealogy",
    "description": "Genealogy domain entities, graph traversal, and public SSR for Waaseyaa",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "repositories": [
        {"type": "path", "url": "../access"},
        {"type": "path", "url": "../cache"},
        {"type": "path", "url": "../config"},
        {"type": "path", "url": "../database-legacy"},
        {"type": "path", "url": "../entity"},
        {"type": "path", "url": "../entity-storage"},
        {"type": "path", "url": "../field"},
        {"type": "path", "url": "../foundation"},
        {"type": "path", "url": "../plugin"},
        {"type": "path", "url": "../relationship"},
        {"type": "path", "url": "../routing"},
        {"type": "path", "url": "../ssr"},
        {"type": "path", "url": "../typed-data"},
        {"type": "path", "url": "../user"},
        {"type": "path", "url": "../validation"},
        {"type": "path", "url": "../workflows"}
    ],
    "autoload": {
        "psr-4": {
            "Waaseyaa\\Genealogy\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\Genealogy\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.5",
        "waaseyaa/access": "^0.1.0-alpha.181",
        "waaseyaa/entity": "^0.1.0-alpha.181",
        "waaseyaa/field": "^0.1.0-alpha.181",
        "waaseyaa/foundation": "^0.1.0-alpha.181",
        "waaseyaa/relationship": "^0.1.0-alpha.181",
        "waaseyaa/routing": "^0.1.0-alpha.181",
        "waaseyaa/ssr": "^0.1.0-alpha.181",
        "waaseyaa/user": "^0.1.0-alpha.181",
        "waaseyaa/workflows": "^0.1.0-alpha.181"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "waaseyaa/api": "^0.1.0-alpha.181",
        "waaseyaa/database-legacy": "^0.1.0-alpha.181",
        "waaseyaa/entity-storage": "^0.1.0-alpha.181"
    },
    "extra": {
        "waaseyaa": {
            "providers": [
                "Waaseyaa\\Genealogy\\GenealogyServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "0.1.x-dev",
            "dev-develop/v1.1": "0.1.x-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "verify:no-api-coupling": "@php scripts/check-no-waaseyaa-api-coupling.php"
    }
}
