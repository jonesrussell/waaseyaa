{
    "name": "waaseyaa/ai-agent",
    "description": "AI agent orchestration and tool execution for Waaseyaa",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "repositories": [
        {
            "type": "path",
            "url": "../access"
        },
        {
            "type": "path",
            "url": "../ai-schema"
        },
        {
            "type": "path",
            "url": "../ai-tools"
        },
        {
            "type": "path",
            "url": "../cache"
        },
        {
            "type": "path",
            "url": "../config"
        },
        {
            "type": "path",
            "url": "../database-legacy"
        },
        {
            "type": "path",
            "url": "../entity"
        },
        {
            "type": "path",
            "url": "../entity-storage"
        },
        {
            "type": "path",
            "url": "../foundation"
        },
        {
            "type": "path",
            "url": "../plugin"
        },
        {
            "type": "path",
            "url": "../typed-data"
        }
    ],
    "require": {
        "php": ">=8.5",
        "waaseyaa/access": "^0.1.0-alpha.180",
        "waaseyaa/ai-schema": "^0.1.0-alpha.180",
        "waaseyaa/ai-tools": "^0.1.0-alpha.180",
        "waaseyaa/database-legacy": "^0.1.0-alpha.180",
        "waaseyaa/entity": "^0.1.0-alpha.180",
        "waaseyaa/entity-storage": "^0.1.0-alpha.180",
        "waaseyaa/foundation": "^0.1.0-alpha.180"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Waaseyaa\\AI\\Agent\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\AI\\Agent\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev",
            "dev-develop/v1.1": "0.1.x-dev"
        },
        "waaseyaa": {
            "providers": [
                "Waaseyaa\\AI\\Agent\\AiAgentEntityServiceProvider",
                "Waaseyaa\\AI\\Agent\\AiAgentServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    }
}
