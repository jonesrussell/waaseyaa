{
    "name": "@waaseyaa/admin",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "description": "Schema-driven admin SPA for Waaseyaa (monorepo workspace member, not published to npm)",
    "engines": {
        "node": ">=22.12.0"
    },
    "scripts": {
        "dev": "nuxt dev",
        "dev:wsl": "nuxt dev --host 0.0.0.0",
        "build": "nuxt build",
        "build:contracts": "tsc -p tsconfig.contracts.json",
        "generate": "nuxt generate",
        "preview": "nuxt preview",
        "postinstall": "nuxt prepare",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "typecheck": "vue-tsc --noEmit",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix"
    },
    "dependencies": {
        "@nuxt/icon": "^2.2.2",
        "nuxt": "4.4.4",
        "vue": "^3.5.34",
        "vue-router": "^5.0.6"
    },
    "devDependencies": {
        "@nuxt/eslint": "^1.15.2",
        "@nuxt/test-utils": "^4.0.3",
        "@playwright/test": "^1.59.1",
        "@types/node": "^25.6.2",
        "@vitest/coverage-v8": "^4.1.5",
        "@vue/test-utils": "^2.4.10",
        "eslint": "^9.39.4",
        "happy-dom": "^20.9.0",
        "typescript": "^6.0.3",
        "vitest": "^4.1.5",
        "vue-tsc": "~2.2.10"
    }
}
