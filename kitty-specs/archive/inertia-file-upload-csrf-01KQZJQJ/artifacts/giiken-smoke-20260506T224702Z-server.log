        "#6 /home/jones/dev/waaseyaa/.worktrees/inertia-file-upload-csrf-01KQZJQJ-lane-b/packages/ssr/src/Http/Router/AppControllerRouter.php(64): Waaseyaa\\SSR\\SsrPageHandler->dispatchAppController()",
        "#7 /home/jones/dev/waaseyaa/.worktrees/inertia-file-upload-csrf-01KQZJQJ-lane-b/packages/foundation/src/Http/ControllerDispatcher.php(89): Waaseyaa\\SSR\\Http\\Router\\AppControllerRouter->handle()",
        "#8 /home/jones/dev/waaseyaa/.worktrees/inertia-file-upload-csrf-01KQZJQJ-lane-b/packages/foundation/src/Kernel/HttpKernel.php(412): Waaseyaa\\Foundation\\Http\\ControllerDispatcher->dispatch()",
        "#9 /home/jones/dev/waaseyaa/.worktrees/inertia-file-upload-csrf-01KQZJQJ-lane-b/packages/foundation/src/Kernel/HttpKernel.php(79): Waaseyaa\\Foundation\\Kernel\\HttpKernel->serveHttpRequest()",
