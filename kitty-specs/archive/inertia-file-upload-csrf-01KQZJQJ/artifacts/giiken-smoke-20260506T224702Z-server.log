    "meta": {
      "exception": "App\\Ingestion\\Converter\\ConversionException",
      "trace": [
        "#0 /home/jones/dev/giiken/src/Ingestion/Handler/CsvIngestionHandler.php(39): App\\Ingestion\\Converter\\MarkItDownConverter->toMarkdown()",
        "#1 /home/jones/dev/giiken/src/Ingestion/IngestionHandlerRegistry.php(27): App\\Ingestion\\Handler\\CsvIngestionHandler->handle()",
        "#2 /home/jones/dev/giiken/src/Http/Controller/ManagementController.php(194): App\\Ingestion\\IngestionHandlerRegistry->handle()",
        "#3 [internal function]: App\\Http\\Controller\\ManagementController->ingestUpload()",
